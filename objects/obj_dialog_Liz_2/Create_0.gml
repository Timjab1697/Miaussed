// Inherit the parent event
event_inherited();

dialog.add(spr_narrador,"Una raton tenia el collar de "+global.gato_name);

dialog.add(spr_player_ab_1,"Mira Lizzie!, un pelo de "+ global.gato_name);

dialog.add(spr_liza,"Eso veo, tal vez los ratones lo atrajeron hasta mi jardin");

dialog.add(spr_player_ab_1,"Eso solo significa que "+global.gato_name+" estuvo aqui hace poco");

dialog.add(spr_liza,"Tienes razon, no debe de estar muy lejos");

dialog.add(spr_player_ab_1,"Pero como puedo saber a donde fue "+global.gato_name+" ?");

dialog.add(spr_liza,"Voy a buscar cerca a mi casa para ver si logro ver a "+global.gato_name);

dialog.add(spr_player_ab_1,"A quien mas puedo pedirle ayuda en el pueblo?");

dialog.add(spr_liza,"Ya hablaste con Milan?");

dialog.add(spr_player_ab_1,"Tienes razon, aun no hablo con Milan, ire a buscarlo");

dialog.add(spr_liza,"Esta bien, mientras tanto te ayudare a buscar a "+global.gato_name+", muchas gracias por ayudarme con los ratones");

dialog.add(spr_narrador,"Habla con Milan");








