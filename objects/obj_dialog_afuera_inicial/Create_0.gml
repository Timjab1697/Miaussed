event_inherited();

dialog.add(spr_joseph,"Hola joven, que linda mañana no crees?");
dialog.add(spr_player_ab_1,"hola, señor Zavarce, no lo creo, estoy buscando a mi gato perdido");
dialog.add(spr_joseph,"Eso es terrible!, un gato perdido puede estar en cualquier parte");
dialog.add(spr_player_ab_1,"Lo se, no tengo idea de por donde empezar a buscarlo");
dialog.add(spr_joseph,"Mira te dare este mapa que muestra como llegar hasta tus vecinos, por si te sirve");
dialog.add(spr_joseph,"Podrias hablar con Vicente, despues de todo tiene una granja, el sabe sobre animales");
dialog.add(spr_joseph,"Espero encuentres a tu gato pronto, estare en mi casa por si necesitas algo");
dialog.add(spr_player_ab_1,"Eso hare señor Zavarce!, muchas gracias");



dialog.add(spr_narrador,"Ahora puedes ver en el camino como llegar hasta tus vecinos");


