// obj_text_input - Create Event
input_text = "";
max_length = 30; // Máximo número de caracteres permitidos
input_active = true; // Controla si la entrada de texto está activa

// Coordenadas y dimensiones del cuadro de entrada de texto (en píxeles)
input_x = 50;
input_y = 50;
input_width = 400; // Ancho del cuadro de entrada de texto
input_height = 50; // Altura del cuadro de entrada de texto