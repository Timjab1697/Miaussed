// Inherit the parent event
event_inherited();
dialog.add(spr_player_ab_1,"Hola milan!");
dialog.add(spr_player_ab_1,"¿Has visto a mi gato, "+global.gato_name+"?");
dialog.add(spr_milan,"¡Oh, hola! No, no he visto a ningún gato últimamente. Pero... ¿estás buscando pistas?");
dialog.add(spr_player_ab_1,"Sí, necesito encontrarlo. ¿Sabes de algo que pueda ayudarme?");
dialog.add(spr_milan,"Bueno, tengo esta lupa. Podría ayudarte a encontrar pistas del gato.");
dialog.add(spr_player_ab_1,"¡Eso sería genial! ¿Puedo tenerla?");
dialog.add(spr_milan,"¡Claro! Pero hay una pequeña condición...");
dialog.add(spr_player_ab_1,"¿Cuál es?");
dialog.add(spr_milan,"Necesito que revientes todos estos globos que sobraron de mi último show.");
dialog.add(spr_player_ab_1,"¿Reventar globos? ¿Por qué?");
dialog.add(spr_milan,"Tenía la idea de sorprender a la gente explotando los globos con la lupa, pero nunca salió el sol. Así que ya no los necesito.");
dialog.add(spr_player_ab_1,"Entiendo. Bueno, si eso es lo que se necesita para obtener la lupa, lo haré.");
