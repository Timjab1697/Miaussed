event_inherited();

dialog.add(spr_player_ab_1,"Hola Vicente!, como va tu dia?");

dialog.add(spr_vicente,"Oh, Hola vecino!, estoy muy bien, tu que tal?");

dialog.add(spr_player_ab_1,"No muy bien, "+ global.gato_name+" , mi gato, desaparecio y no se donde esta");

dialog.add(spr_vicente,"Vaya, eso es malo, lo siento mucho, amigo");

dialog.add(spr_player_ab_1,"No lo habras visto por ahi?");

dialog.add(spr_vicente,"De hecho, ahora que lo dices, esta manana oi ruidos en mi patio");

dialog.add(spr_player_ab_1,"Podria pasar a ver si encuentro algun rastro de el?");

dialog.add(spr_vicente,"Claro!, y ya que estas ahi atras podrias darme una mano organizando unas manzanas? por favor");

dialog.add(spr_player_ab_1,"Por supuesto!, muchas gracias Vicente!");

